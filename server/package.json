{
  "name": "antigravity-signal-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "prisma generate",
    "start": "node src/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "node scripts/wait-for-db.js && prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:sqlite": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.5.0",
    "stripe": "^17.7.0",
    "zod": "^3.24.2"
  }
}
