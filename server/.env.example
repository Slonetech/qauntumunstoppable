# Server — copy to server/.env (local) or set in Railway → Variables
NODE_ENV=development
PORT=3001

# PostgreSQL
# Local (docker-compose): postgresql://asp:asp_dev_password@localhost:5432/antigravity_signal?schema=public
# Railway: paste DATABASE_URL from Railway PostgreSQL plugin (auto-injected if linked)
DATABASE_URL="postgresql://asp:asp_dev_password@localhost:5432/antigravity_signal?schema=public"

# Auth — generate: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Admin (server-side only — never expose to frontend or Vercel)
ADMIN_PASSWORD=change_me_admin_password

# CORS — comma-separated allowed frontend origins (credentials/cookies)
# Local:
CLIENT_ORIGIN=http://localhost:5173
# Production example (both URLs if you use www + apex):
# CLIENT_ORIGIN=https://your-app.vercel.app,https://www.your-domain.com

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook endpoint: https://YOUR-RAILWAY-URL.up.railway.app/api/webhooks/stripe
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ELITE=
